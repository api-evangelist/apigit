{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/api-evangelist/apigit/refs/heads/main/json-schema/apigit-repository-schema.json",
  "title": "Repository",
  "description": "An APIGit API repository.",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "example": "repo-001"
    },
    "name": {
      "type": "string",
      "example": "my-api"
    },
    "description": {
      "type": "string"
    },
    "visibility": {
      "type": "string",
      "enum": [
        "public",
        "private"
      ]
    }
  }
}